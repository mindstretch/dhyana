{
  "version": 2,
  "builds": [
    { "src": "src/app/api/subscribe/route.ts", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/subscribe", "dest": "/src/app/api/subscribe/route.ts" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
